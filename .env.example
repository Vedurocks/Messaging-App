# Database (Neon integration named "NeonDB", database: neon-coral-book).
# Vercel prefixes vars per-integration to avoid collisions, so this
# project's actual vars are NeonDB_DATABASE_URL / NeonDB_POSTGRES_URL.
# lib/db.ts checks those first, then falls back to the unprefixed names
# below for local dev or a differently-named integration.
NeonDB_DATABASE_URL=""
NeonDB_POSTGRES_URL=""
DATABASE_URL=""
POSTGRES_URL=""

# Session / JWT secrets (generate with: openssl rand -base64 32)
SESSION_SECRET=""
REFRESH_SECRET=""

# Next.js
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: Redis for scaling SSE across multiple server instances
# (realtime.ts falls back to in-memory if unset — fine for single-instance dev)
# REDIS_URL="redis://localhost:6379"
